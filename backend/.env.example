# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://user:password@host:5432/warpfix

# Redis
REDIS_URL=redis://localhost:6379

# LLM provider fallback chain (comma-separated, tried in order). Each provider
# is tried until one succeeds; a per-day cap or exhausted paid credits on one
# falls through to the next, so repairs keep working at $0.
# Supported providers: "groq", "github", "hf" (HuggingFace paid key),
# "hffree" (HuggingFace free key).
LLM_PROVIDER=groq,github,hf,hffree

# Groq (OpenAI-compatible, free tier) - primary
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# GitHub Models (OpenAI-compatible, free with a GitHub token) - fallback
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# HuggingFace Inference Providers (OpenAI-compatible router). Two keys so a paid
# PRO key is used first ("hf") and the chain falls through to a free key
# ("hffree") once the PRO monthly credits are exhausted. Both hit the same API.
HUGGINGFACE_API_KEY=
HUGGINGFACE_API_KEY_FREE=
HUGGINGFACE_API_URL=https://router.huggingface.co/v1
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Patch-prompt token budget (free-tier friendly). Lower = fewer tokens/repair.
PATCH_MAX_TOKENS=4000
PATCH_MAX_FILES=4
PATCH_FILE_CHARS=3500
PATCH_SRC_CHAR_BUDGET=12000

# Dodo Payments
DODO_API_KEY=
DODO_API_URL=https://live.dodopayments.com
DODO_WEBHOOK_SECRET=
DODO_PRO_PRODUCT_ID=pdt_0Ndi5McnUkYnmcneC5Lc7
DODO_TEAM_PRODUCT_ID=pdt_0Ndi5OJovSYC93Y51BlZ5

# App
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
NODE_ENV=development
PORT=4000
SESSION_SECRET=change-me-in-production

# Sandbox
SANDBOX_TIMEOUT_MS=120000
SANDBOX_MAX_CONCURRENT=3
