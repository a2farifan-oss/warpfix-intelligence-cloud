# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://user:password@host:5432/warpfix

# Redis
REDIS_URL=redis://localhost:6379

# LLM provider fallback chain (comma-separated, tried in order).
# Supported providers: "groq", "github".
LLM_PROVIDER=groq,github

# Groq (OpenAI-compatible, free tier) - primary
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# GitHub Models (OpenAI-compatible, free with a GitHub token) - fallback
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Dodo Payments
DODO_API_KEY=
DODO_API_URL=https://live.dodopayments.com
DODO_WEBHOOK_SECRET=
DODO_PRO_PRODUCT_ID=pdt_0Ndi5McnUkYnmcneC5Lc7
DODO_TEAM_PRODUCT_ID=pdt_0Ndi5OJovSYC93Y51BlZ5

# App
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
NODE_ENV=development
PORT=4000
SESSION_SECRET=change-me-in-production

# Sandbox
SANDBOX_TIMEOUT_MS=120000
SANDBOX_MAX_CONCURRENT=3
